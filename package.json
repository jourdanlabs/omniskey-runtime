{
  "name": "omniskey-runtime",
  "version": "0.1.0",
  "description": "OMNIS KEY Runtime verified agent runtime with silent BIFROST/CLARION checks.",
  "license": "SEE LICENSE.md",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "installers",
    "README.md",
    "LICENSE.md",
    "NOTICE.md",
    "TRADEMARKS.md",
    "COMMERCIAL_LICENSE.md"
  ],
  "bin": {
    "omniskey-runtime": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').chmodSync('dist/src/cli.js', 0o755)\"",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
